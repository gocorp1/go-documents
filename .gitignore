# Credentials — NEVER commit
manifest.json
.env
.env.*
credentials/
*.key
*.pem
*.p12
*.pfx

# Specific credential files
ai-agents-go-*.json
client_secret_*.json
*_tokens.json
token_*.json
*_token.json
*credentials*.json
*secret*.json

# Peak API
Peak*.env

# Notion
NOTION_API_KEY*

# Build artifacts
verify-report.json
verify-report.txt
build-meta.json

# Node
node_modules/
npm-debug.log*
package-lock.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Session state (Rule 6) — per-user local state, not committed
.claude/PROGRESS.md
.claude/sessions/
.claude/cache/
.claude/backups/
.claude/debug/
.claude/downloads/
.claude/telemetry/
.claude/worktrees/
.claude/settings.json
.claude/settings.local.json

# Per-Rule-5 machine-local state — must NEVER be committed
# (ported from data-communications v0.5.14 / go-access-gateway v0.6.9)
.claude/autocommit.opt-in
.claude/autocommit.opt-in.*
.claude/active-machine.*
.claude/scheduled_tasks.lock
.claude/autocommit.opt-out
.claude/session-state.*

# Archived / corrupt / host-fork .git directories (Rule 5c)
.git-*.archived-*
.git.broken-*
.git-*.bak.*
.git-NUC9/

# OneDrive multi-machine race-suffix duplicates (Rule 5h)
-NCORE100.*
-NUC9.*
-LAPTOP.*
*-NCORE100.*
*-NUC9.*
*-LAPTOP.*
